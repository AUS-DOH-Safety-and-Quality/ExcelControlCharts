{
  "name": "office-addin-taskpane",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/OfficeDev/Office-Addin-TaskPane.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "excel",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "lint": "office-addin-lint check --files=\"src/{taskpane,commands,utilities}/*.ts\"",
    "lint:fix": "office-addin-lint fix --files=\"src/{taskpane,commands,utilities}/*.ts\"",
    "prettier": "office-addin-lint prettier --files=\"src/{taskpane,commands,utilities}/*.ts\"",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "watch": "webpack --mode development --watch"
  },
  "dependencies": {
    "core-js": "^3.36.0",
    "d3-axis": "^3.0.0",
    "d3-drag": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "powerbi-visuals-api": "~5.1.0",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/office-js": "^1.0.591",
    "@types/office-runtime": "^1.0.37",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint-plugin-office-addins": "^4.0.9",
    "file-loader": "^6.2.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "office-addin-cli": "^2.0.9",
    "office-addin-debugging": "^6.1.1",
    "office-addin-dev-certs": "^2.0.9",
    "office-addin-lint": "^3.0.9",
    "office-addin-manifest": "^2.1.5",
    "office-addin-prettier-config": "^2.0.4",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "source-map-loader": "^5.0.0",
    "typescript": "^5.9.3",
    "webpack": "^5.107.1",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "5.2.4"
  },
  "overrides": {
    "office-addin-manifest" : {
      "uuid": "^11.1.1"
    },
    "webpack-dev-server" : {
      "uuid": "^11.1.1"
    },
    "office-addin-debugging": {
      "uuid": "^11.1.1"
    }
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 versions",
    "ie 11"
  ]
}
